# Copy to .env for local dev. NEVER commit real values.
# Client-visible (safe to expose):
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
VITE_SUPABASE_PROJECT_ID="YOUR-PROJECT-ID"

# Server-only (set in your hosting platform's env vars — Vercel/Netlify/etc):
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."   # SECRET — never expose
STRIPE_SECRET_KEY="sk_live_..."             # SECRET — use sk_test_ locally
